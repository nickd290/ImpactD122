generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  User              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Campaign {
  id                 String            @id
  externalCampaignId String            @unique
  customerId         String
  name               String
  sizeName           String
  quantity           Int
  frequency          CampaignFrequency
  mailDay            Int
  startDate          DateTime
  endDate            DateTime?
  isActive           Boolean           @default(true)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime
  Company            Company           @relation(fields: [customerId], references: [id])
  CampaignDrop       CampaignDrop[]

  @@index([customerId])
  @@index([isActive])
}

model CampaignDrop {
  id             String     @id
  campaignId     String
  mailDate       DateTime
  uploadDeadline DateTime
  status         DropStatus @default(SCHEDULED)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime
  Campaign       Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([mailDate])
}

model ChangeOrder {
  id              String            @id
  jobId           String
  changeOrderNo   String            @unique
  version         Int
  summary         String
  changes         Json
  status          ChangeOrderStatus @default(DRAFT)
  approvedAt      DateTime?
  approvedBy      String?
  rejectionReason String?
  affectsVendors  String[]
  requiresNewPO   Boolean           @default(false)
  requiresReprice Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  Job             Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, version])
  @@index([jobId])
  @@index([status])
}

model Company {
  id                                                   String              @id
  name                                                 String
  type                                                 String
  email                                                String?
  phone                                                String?
  address                                              String?
  createdAt                                            DateTime            @default(now())
  updatedAt                                            DateTime
  Campaign                                             Campaign[]
  Employee                                             Employee[]
  Invoice_Invoice_fromCompanyIdToCompany               Invoice[]           @relation("Invoice_fromCompanyIdToCompany")
  Invoice_Invoice_toCompanyIdToCompany                 Invoice[]           @relation("Invoice_toCompanyIdToCompany")
  Job                                                  Job[]
  PurchaseOrder_PurchaseOrder_originCompanyIdToCompany PurchaseOrder[]     @relation("PurchaseOrder_originCompanyIdToCompany")
  PurchaseOrder_PurchaseOrder_targetCompanyIdToCompany PurchaseOrder[]     @relation("PurchaseOrder_targetCompanyIdToCompany")
  QuoteRequest                                         QuoteRequest[]
  ShipmentRecipient                                    ShipmentRecipient[]
  User                                                 User[]
}

model EmailLog {
  id        String   @id
  jobId     String
  emailType String
  sentTo    String
  sentAt    DateTime @default(now())
  success   Boolean
  messageId String?
  skipped   Boolean  @default(false)
  error     String?
  Job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, emailType])
  @@index([jobId, emailType, sentAt])
  @@index([sentAt])
}

model Employee {
  id        String   @id
  companyId String
  name      String
  email     String
  phone     String?
  position  String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime
  Company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  Job       Job[]

  @@index([companyId])
}

model File {
  id            String          @id
  kind          FileKind
  jobId         String?
  objectKey     String
  fileName      String
  mimeType      String
  size          Int
  checksum      String
  uploadedBy    String?
  createdAt     DateTime        @default(now())
  Job           Job?            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  FileShare     FileShare[]
  Invoice       Invoice[]
  Proof         Proof[]
  PurchaseOrder PurchaseOrder[]

  @@index([jobId])
  @@index([kind])
}

model FileShare {
  id          String    @id
  fileId      String
  shareToken  String    @unique
  expiresAt   DateTime
  accessedAt  DateTime?
  accessCount Int       @default(0)
  createdFor  String?
  createdBy   String?
  createdAt   DateTime  @default(now())
  File        File      @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([fileId])
  @@index([shareToken])
}

model Invoice {
  id                                     String    @id
  jobId                                  String?
  toCompanyId                            String
  fromCompanyId                          String
  invoiceNo                              String    @unique
  amount                                 Decimal
  pdfFileId                              String?
  issuedAt                               DateTime?
  dueAt                                  DateTime?
  paidAt                                 DateTime?
  createdAt                              DateTime  @default(now())
  updatedAt                              DateTime
  Company_Invoice_fromCompanyIdToCompany Company   @relation("Invoice_fromCompanyIdToCompany", fields: [fromCompanyId], references: [id])
  Job                                    Job?      @relation(fields: [jobId], references: [id])
  File                                   File?     @relation(fields: [pdfFileId], references: [id])
  Company_Invoice_toCompanyIdToCompany   Company   @relation("Invoice_toCompanyIdToCompany", fields: [toCompanyId], references: [id])

  @@index([fromCompanyId])
  @@index([jobId])
  @@index([toCompanyId])
}

model Job {
  id                                 String                    @id
  jobNo                              String                    @unique
  title                              String?
  customerId                         String
  vendorId                           String?
  customerPONumber                   String?
  notes                              String?
  createdAt                          DateTime                  @default(now())
  updatedAt                          DateTime
  specs                              Json
  activeTask                         String?
  activeTaskCreatedAt                DateTime?
  activeTaskCreatedBy                String?
  approvedAt                         DateTime?
  approvedBy                         String?
  artOverride                        Boolean                   @default(false)
  artOverrideAt                      DateTime?
  artOverrideBy                      String?
  artOverrideNote                    String?
  artworkEmailedAt                   DateTime?
  artworkEmailedTo                   String?
  artworkSectionComplete             Boolean                   @default(false)
  baseJobId                          String?                   @unique
  bradfordBuyCost                    Decimal?                  @db.Decimal(10, 2)
  bradfordPaperCostPerLb             Decimal?                  @db.Decimal(10, 4)
  bradfordPaperLbs                   Decimal?                  @db.Decimal(10, 2)
  bradfordPaperType                  String?
  bradfordPaymentAmount              Decimal?
  bradfordPaymentDate                DateTime?
  bradfordPaymentPaid                Boolean                   @default(false)
  bradfordPrintCPM                   Decimal?                  @db.Decimal(10, 4)
  bradfordWaivesPaperMargin          Boolean                   @default(false)
  completedAt                        DateTime?
  customerJobNumber                  String?
  customerPOFile                     String?
  customerPaymentAmount              Decimal?
  customerPaymentDate                DateTime?
  dataFilesSectionComplete           Boolean                   @default(false)
  dataIncludedWithArtwork            Boolean                   @default(false)
  dataOverride                       String?
  dataOverrideAt                     DateTime?
  dataOverrideBy                     String?
  dataOverrideNote                   String?
  deletedAt                          DateTime?
  deletedBy                          String?
  deliveryDate                       DateTime?
  description                        String?
  effectiveCOVersion                 Int?
  employeeId                         String?
  envelopeComponents                 Int?
  externalJobId                      String?                   @unique
  externalSource                     String?
  hasData                            Boolean                   @default(false)
  hasSamples                         Boolean                   @default(false)
  hasVersions                        Boolean                   @default(false)
  inHomesDate                        DateTime?
  invoiceEmailedAt                   DateTime?
  invoiceEmailedCount                Int                       @default(0)
  invoiceEmailedTo                   String?
  invoiceGeneratedAt                 DateTime?
  invoiceGeneratedCount              Int                       @default(0)
  isReadyForProduction               Boolean                   @default(false)
  jdInvoiceEmailedAt                 DateTime?
  jdInvoiceEmailedTo                 String?
  jdInvoiceGeneratedAt               DateTime?
  jdInvoiceNumber                    String?
  jdPaymentAmount                    Decimal?
  jdPaymentDate                      DateTime?
  jdPaymentPaid                      Boolean                   @default(false)
  jdSuppliesPaper                    Boolean                   @default(false)
  jobMetaType                        JobMetaType?
  jobType                            JobType?
  jobTypeCode                        String?
  mailDate                           DateTime?
  mailFormat                         MailFormat?
  mailingVendorId                    String?
  mailingVendorJobNo                 String?
  mailingVendorPOSent                DateTime?
  mailingVendorPOSentTo              String?
  masterSeq                          Int?                      @unique
  matchType                          String?
  packingSlipNotes                   String?
  paperInventoryId                   String?
  paperSource                        PaperSource               @default(BRADFORD)
  partnerPONumber                    String?
  pathway                            Pathway?
  poGeneratedAt                      DateTime?
  poGeneratedCount                   Int                       @default(0)
  proofOverride                      ProofStatus?
  proofOverrideAt                    DateTime?
  proofOverrideBy                    String?
  proofOverrideNote                  String?
  qcArtwork                          QcArtworkStatus           @default(PENDING)
  qcArtworkNote                      String?
  qcDataFiles                        QcDataFilesStatus         @default(NA)
  qcDataFilesNote                    String?
  qcMailing                          QcMailingStatus           @default(NA)
  qcMailingNote                      String?
  qcSuppliedMaterials                QcSuppliedMaterialsStatus @default(NA)
  qcSuppliedMaterialsNote            String?
  qcVersions                         QcVersionsStatus          @default(NA)
  qcVersionsNote                     String?
  quantity                           Int?
  quoteGeneratedAt                   DateTime?
  quoteGeneratedCount                Int                       @default(0)
  quoteId                            String?
  readinessCalculatedAt              DateTime?
  readinessStatus                    ReadinessStatus           @default(INCOMPLETE)
  requiredArtworkCount               Int?
  requiredDataFileCount              Int?
  requiresApproval                   Boolean                   @default(false)
  routingType                        RoutingType               @default(BRADFORD_JD)
  sellPrice                          Decimal?
  sizeId                             String?
  sizeName                           String?
  submittedForProductionAt           DateTime?
  trackingCarrierOverride            String?
  trackingOverride                   String?
  trackingOverrideAt                 DateTime?
  trackingOverrideBy                 String?
  vendorConfirmOverride              Boolean                   @default(false)
  vendorConfirmOverrideAt            DateTime?
  vendorConfirmOverrideBy            String?
  vendorConfirmOverrideNote          String?
  vendorCount                        Int?
  vendorPaymentAmount                Decimal?
  vendorPaymentDate                  DateTime?
  vendorPaymentTerms                 String?
  vendorShipToAddress                String?
  vendorShipToCity                   String?
  vendorShipToName                   String?
  vendorShipToPhone                  String?
  vendorShipToState                  String?
  vendorShipToZip                    String?
  vendorSpecialInstructions          String?
  workflowStatus                     JobWorkflowStatus         @default(NEW_JOB)
  workflowStatusOverride             String?
  workflowStatusOverrideAt           DateTime?
  workflowStatusOverrideBy           String?
  workflowUpdatedAt                  DateTime?
  status                             JobStatus                 @default(ACTIVE)
  poEmailedAt                        DateTime?
  poEmailedTo                        String?
  customerResponseDue                DateTime?
  proofReceivedAt                    DateTime?
  proofSentToCustomerAt              DateTime?
  proofUrgency                       ProofUrgency?
  proofUrgencyNote                   String?
  ChangeOrder                        ChangeOrder[]
  EmailLog                           EmailLog[]
  File                               File[]
  Invoice                            Invoice[]
  Company                            Company                   @relation(fields: [customerId], references: [id])
  Employee                           Employee?                 @relation(fields: [employeeId], references: [id])
  MailingVendor                      Vendor?                   @relation("Job_mailingVendorIdToVendor", fields: [mailingVendorId], references: [id])
  PaperInventory                     PaperInventory?           @relation(fields: [paperInventoryId], references: [id])
  Quote                              Quote?                    @relation(fields: [quoteId], references: [id])
  Vendor                             Vendor?                   @relation("Job_vendorIdToVendor", fields: [vendorId], references: [id])
  JobActivity                        JobActivity[]
  JobCommunication                   JobCommunication[]
  JobComponent                       JobComponent[]
  JobEmailThread                     JobEmailThread[]
  JobEvent                           JobEvent[]
  JobPortal                          JobPortal?
  Notification                       Notification[]
  ProfitSplit                        ProfitSplit?
  Proof                              Proof[]
  PurchaseOrder                      PurchaseOrder[]
  SampleShipment                     SampleShipment[]
  Shipment                           Shipment[]
  VendorRFQ                          VendorRFQ[]

  @@index([baseJobId])
  @@index([customerId])
  @@index([deletedAt])
  @@index([jobNo])
  @@index([jobType])
  @@index([mailingVendorId])
  @@index([paperInventoryId])
  @@index([paperSource])
  @@index([pathway])
  @@index([readinessStatus])
  @@index([routingType])
  @@index([status])
  @@index([vendorId])
}

model JobActivity {
  id            String   @id
  jobId         String
  action        String
  field         String?
  oldValue      String?
  newValue      String?
  changedBy     String
  changedByRole Role
  createdAt     DateTime @default(now())
  Job           Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([jobId])
}

model JobCommunication {
  id                         String                       @id
  jobId                      String
  direction                  CommunicationDirection
  senderType                 SenderType
  originalFrom               String
  originalTo                 String
  originalSubject            String
  maskedFrom                 String?
  maskedSubject              String?
  textBody                   String?
  htmlBody                   String?
  status                     CommunicationStatus          @default(RECEIVED)
  forwardedAt                DateTime?
  forwardedTo                String?
  forwardedBy                String?
  messageId                  String?
  inReplyTo                  String?
  internalNotes              String?
  receivedAt                 DateTime                     @default(now())
  createdAt                  DateTime                     @default(now())
  updatedAt                  DateTime
  Job                        Job                          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  JobCommunicationAttachment JobCommunicationAttachment[]

  @@index([direction])
  @@index([jobId])
  @@index([receivedAt])
  @@index([status])
}

model JobCommunicationAttachment {
  id               String           @id
  communicationId  String
  fileName         String
  mimeType         String
  size             Int
  objectKey        String?
  contentBase64    String?
  createdAt        DateTime         @default(now())
  JobCommunication JobCommunication @relation(fields: [communicationId], references: [id], onDelete: Cascade)

  @@index([communicationId])
}

model JobComponent {
  id                String                  @id
  jobId             String
  name              String
  description       String?
  quantity          Int?
  supplier          ComponentSupplier       @default(JD)
  supplierName      String?
  componentType     ComponentType?
  owner             ComponentOwner?
  vendorId          String?
  status            ComponentStatus         @default(NOT_READY)
  artworkRequired   Boolean?
  dataRequired      Boolean?
  dueDate           DateTime?
  artworkStatus     ComponentArtworkStatus  @default(PENDING)
  artworkLink       String?
  artworkReceivedAt DateTime?
  materialStatus    ComponentMaterialStatus @default(NA)
  trackingNumber    String?
  trackingCarrier   String?
  expectedArrival   DateTime?
  receivedAt        DateTime?
  specs             Json?
  notes             String?
  sortOrder         Int                     @default(0)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime
  Job               Job                     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  Vendor            Vendor?                 @relation(fields: [vendorId], references: [id])

  @@index([componentType])
  @@index([jobId])
  @@index([owner])
  @@index([supplier])
  @@index([vendorId])
}

model JobEmailThread {
  id                String     @id
  threadId          String     @unique
  firstMessageId    String
  jobId             String?
  customerPONumber  String?
  customerDomain    String?
  subjectNormalized String
  lastMessageAt     DateTime
  lastSyncedAt      DateTime
  createdAt         DateTime   @default(now())
  Job               Job?       @relation(fields: [jobId], references: [id])
  JobEvent          JobEvent[]

  @@index([customerPONumber])
  @@index([jobId])
  @@index([threadId])
}

model JobEvent {
  id             String         @id
  jobId          String?
  threadId       String
  messageId      String         @unique
  type           JobEventType
  confidence     Float
  source         String
  signals        String[]
  links          String[]
  needsReview    Boolean        @default(false)
  reviewNote     String?
  createdAt      DateTime       @default(now())
  Job            Job?           @relation(fields: [jobId], references: [id])
  JobEmailThread JobEmailThread @relation(fields: [threadId], references: [threadId])

  @@index([createdAt])
  @@index([jobId])
  @@index([needsReview])
  @@index([threadId])
}

model JobPortal {
  id               String             @id
  jobId            String             @unique
  shareToken       String             @unique
  expiresAt        DateTime
  accessedAt       DateTime?
  accessCount      Int                @default(0)
  createdAt        DateTime           @default(now())
  purchaseOrderId  String?
  confirmedAt      DateTime?
  confirmedByName  String?
  confirmedByEmail String?
  vendorStatus     VendorPortalStatus @default(PENDING)
  statusUpdatedAt  DateTime?
  trackingNumber   String?
  trackingCarrier  String?
  Job              Job                @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([shareToken])
}

model JobSequence {
  id           String   @id @default("job-seq")
  currentValue Int      @default(1000)
  updatedAt    DateTime
}

model MasterSequence {
  id           String   @id @default("master-seq")
  currentValue Int      @default(3000)
  updatedAt    DateTime
}

model Notification {
  id        String           @id
  type      NotificationType
  jobId     String?
  recipient String
  subject   String
  body      String
  sentAt    DateTime?
  createdAt DateTime         @default(now())
  Job       Job?             @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([recipient])
}

model PaperInventory {
  id               String             @id
  rollType         String
  rollWidth        Int
  paperPoint       Int
  paperType        String
  quantity         Int
  weightPerRoll    Decimal?
  reorderPoint     Int?
  companyId        String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  Job              Job[]
  PaperTransaction PaperTransaction[]

  @@index([companyId])
  @@index([rollType])
}

model PaperTransaction {
  id             String         @id
  inventoryId    String
  type           String
  quantity       Int
  jobId          String?
  notes          String?
  userId         String?
  createdAt      DateTime       @default(now())
  PaperInventory PaperInventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([inventoryId])
  @@index([jobId])
}

model PricingRule {
  id                  String   @id
  sizeName            String   @unique
  baseCPM             Decimal
  printCPM            Decimal
  paperWeightPer1000  Decimal?
  paperCostPerLb      Decimal?
  paperCPM            Decimal?
  paperChargedCPM     Decimal?
  rollSize            Int?
  isActive            Boolean  @default(true)
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime
  bradfordInvoicePerM Decimal?
  impactInvoicePerM   Decimal?
  jdInvoicePerM       Decimal?
  paperMarkupPercent  Decimal?

  @@index([isActive])
  @@index([sizeName])
}

model ProfitSplit {
  id                 String    @id
  jobId              String    @unique
  sellPrice          Decimal
  totalCost          Decimal
  paperCost          Decimal   @default(0)
  paperMarkup        Decimal   @default(0)
  grossMargin        Decimal
  bradfordShare      Decimal
  impactShare        Decimal
  isOverridden       Boolean   @default(false)
  overrideReason     String?
  overriddenBy       String?
  overriddenAt       DateTime?
  calculatedAt       DateTime  @default(now())
  calculationVersion Int       @default(1)
  Job                Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

model Proof {
  id               String          @id
  jobId            String
  version          Int
  status           ProofStatus     @default(PENDING)
  fileId           String?
  adminNotes       String?
  adminComments    String?
  shareToken       String?         @unique
  shareExpiresAt   DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime
  approvalComments String?
  approvedAt       DateTime?
  approvedByEmail  String?
  approvedByName   String?
  File             File?           @relation(fields: [fileId], references: [id])
  Job              Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  ProofApproval    ProofApproval[]

  @@unique([jobId, version])
  @@index([jobId])
  @@index([shareToken])
}

model ProofApproval {
  id         String   @id
  proofId    String
  approved   Boolean
  comments   String?
  approvedBy String?
  createdAt  DateTime @default(now())
  Proof      Proof    @relation(fields: [proofId], references: [id], onDelete: Cascade)

  @@index([proofId])
}

model PurchaseOrder {
  id                                             String    @id
  originCompanyId                                String
  targetCompanyId                                String?
  jobId                                          String?
  poNumber                                       String?   @unique
  status                                         POStatus  @default(PENDING)
  createdAt                                      DateTime  @default(now())
  updatedAt                                      DateTime
  executionId                                    String?   @unique
  description                                    String?
  buyCost                                        Decimal?
  vendorRef                                      String?
  paperCost                                      Decimal?
  paperMarkup                                    Decimal?
  mfgCost                                        Decimal?
  printCPM                                       Decimal?
  paperCPM                                       Decimal?
  issuedAt                                       DateTime?
  paidAt                                         DateTime?
  pdfFileId                                      String?
  targetVendorId                                 String?
  acceptedAt                                     DateTime?
  rejectedAt                                     DateTime?
  rejectionReason                                String?
  emailedAt                                      DateTime?
  emailedTo                                      String?
  artworkFilesLink                               String?
  specialInstructions                            String?
  pdfUrl                                         String?
  Job                                            Job?      @relation(fields: [jobId], references: [id])
  Company_PurchaseOrder_originCompanyIdToCompany Company   @relation("PurchaseOrder_originCompanyIdToCompany", fields: [originCompanyId], references: [id])
  File                                           File?     @relation(fields: [pdfFileId], references: [id])
  Company_PurchaseOrder_targetCompanyIdToCompany Company?  @relation("PurchaseOrder_targetCompanyIdToCompany", fields: [targetCompanyId], references: [id])
  Vendor                                         Vendor?   @relation(fields: [targetVendorId], references: [id])

  @@index([jobId])
  @@index([originCompanyId])
  @@index([targetCompanyId])
  @@index([targetVendorId])
}

model Quote {
  id             String       @id
  quoteRequestId String
  lines          Json
  subtotal       Decimal
  tax            Decimal      @default(0)
  total          Decimal
  validUntil     DateTime
  notes          String?
  approvedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime
  Job            Job[]
  QuoteRequest   QuoteRequest @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)

  @@index([quoteRequestId])
}

model QuoteRequest {
  id         String             @id
  customerId String
  status     QuoteRequestStatus @default(PENDING)
  specs      Json
  createdAt  DateTime           @default(now())
  updatedAt  DateTime
  Quote      Quote[]
  Company    Company            @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([status])
}

model SampleShipment {
  id               String    @id
  jobId            String
  description      String
  carrier          String
  trackingNo       String?
  recipientName    String
  recipientEmail   String
  recipientAddress String?
  sentAt           DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime
  Job              Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([trackingNo])
}

model Shipment {
  id                String              @id
  jobId             String
  carrier           String
  trackingNo        String?
  weight            Decimal?
  boxes             Int?
  scheduledAt       DateTime?
  shippedAt         DateTime?
  deliveredAt       DateTime?
  trackingEmailedAt DateTime?
  trackingEmailedTo String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  Job               Job                 @relation(fields: [jobId], references: [id], onDelete: Cascade)
  ShipmentRecipient ShipmentRecipient[]

  @@index([jobId])
  @@index([trackingNo])
}

model ShipmentRecipient {
  id         String   @id
  shipmentId String
  companyId  String?
  name       String
  address    String
  city       String
  state      String
  zip        String
  phone      String?
  createdAt  DateTime @default(now())
  Company    Company? @relation(fields: [companyId], references: [id])
  Shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
}

model SyncLog {
  id              String      @id
  trigger         SyncTrigger
  purchaseOrderId String?
  invoiceId       String?
  jobId           String?
  field           String
  oldValue        Decimal?
  newValue        Decimal
  changedBy       String?
  notes           String?
  createdAt       DateTime    @default(now())

  @@index([createdAt])
  @@index([invoiceId])
  @@index([jobId])
  @@index([purchaseOrderId])
}

model User {
  id            String    @id
  email         String    @unique
  emailVerified DateTime?
  password      String?
  name          String?
  role          Role      @default(CUSTOMER)
  companyId     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
  Account       Account[]
  Company       Company?  @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([email])
}

model Vendor {
  id                              String            @id
  name                            String
  email                           String?
  phone                           String?
  isActive                        Boolean           @default(true)
  isPartner                       Boolean           @default(false)
  isInternal                      Boolean           @default(false)
  createdAt                       DateTime          @default(now())
  updatedAt                       DateTime
  city                            String?
  country                         String?           @default("USA")
  state                           String?
  streetAddress                   String?
  vendorCode                      String?           @unique
  zip                             String?
  MailingJobs                     Job[]             @relation("Job_mailingVendorIdToVendor")
  Jobs                            Job[]             @relation("Job_vendorIdToVendor")
  JobComponent                    JobComponent[]
  PurchaseOrder                   PurchaseOrder[]
  VendorContact                   VendorContact[]
  VendorQuote                     VendorQuote[]
  VendorRFQVendor                 VendorRFQVendor[]

  @@index([isActive])
  @@index([isInternal])
  @@index([name])
}

model VendorContact {
  id        String   @id
  vendorId  String
  name      String
  email     String
  title     String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime
  Vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
}

model VendorQuote {
  id             String            @id
  rfqId          String
  vendorId       String
  quoteAmount    Decimal?          @db.Decimal(10, 2)
  priceTiers     Json?
  turnaroundDays Int?
  notes          String?
  status         VendorQuoteStatus @default(PENDING)
  isAwarded      Boolean           @default(false)
  respondedAt    DateTime?
  emailContent   String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime
  VendorRFQ      VendorRFQ         @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  Vendor         Vendor            @relation(fields: [vendorId], references: [id])

  @@unique([rfqId, vendorId])
  @@index([rfqId])
  @@index([status])
  @@index([vendorId])
}

model VendorRFQ {
  id              String            @id
  rfqNumber       String            @unique
  title           String
  specs           String
  dueDate         DateTime
  status          RFQStatus         @default(DRAFT)
  notes           String?
  jobId           String?
  createdById     String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  VendorQuote     VendorQuote[]
  Job             Job?              @relation(fields: [jobId], references: [id])
  VendorRFQVendor VendorRFQVendor[]

  @@index([dueDate])
  @@index([jobId])
  @@index([status])
}

model VendorRFQVendor {
  id         String    @id
  rfqId      String
  vendorId   String
  sentAt     DateTime?
  quoteToken String?   @unique
  createdAt  DateTime  @default(now())
  VendorRFQ  VendorRFQ @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  Vendor     Vendor    @relation(fields: [vendorId], references: [id])

  @@unique([rfqId, vendorId])
  @@index([rfqId])
  @@index([vendorId])
}

model WebhookEvent {
  id        String        @id
  source    WebhookSource
  payload   Json
  processed Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime

  @@index([processed])
  @@index([source])
}

